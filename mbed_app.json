{
    "requires": ["bare-metal"],
    "target_overrides": {
        "*": {
            "target.macros_add": ["__irq="],
            "target.default_lib": "small",
            "target.printf_lib": "minimal-printf",
            "platform.minimal-printf-enable-floating-point": true
        },
        "LPC1768": {
            "target.linker_script": "custom_LPC1768.ld"
        }
    }
}
